<mah:MetroWindow x:Class="Busan_Restaurant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Busan_Restaurant"
        mc:Ignorable="d"
        Title="부산 지역별 맛집 정보" Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        TitleAlignment="Left"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="부산 지역 선택" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Margin="0,0,15,0"/>

            <ComboBox Width="200" Height="35" 
                      ItemsSource="{Binding Districts}" 
                      SelectedItem="{Binding SelectedDistrict}"
                      mah:TextBoxHelper.Watermark="지역을 선택하세요"
                      Style="{StaticResource MahApps.Styles.ComboBox}"/>
        </StackPanel>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding FilteredRestaurants}" 
                 SelectedItem="{Binding SelectedRestaurant}"
                 HorizontalContentAlignment="Stretch" 
                 BorderThickness="0"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="True">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource MahApps.Styles.ListBoxItem}">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="6" Padding="15" Margin="2">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#DDDDDD" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="8" ClipToBounds="True" Width="100" Height="100" VerticalAlignment="Top">
                                <Image Source="{Binding ImageUrl, IsAsync=True}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                <TextBlock Text="{Binding Title}" FontSize="14" Foreground="#555555" Margin="0,5,0,5" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    
                                    <TextBlock Text="{Binding PhoneNumber}" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{Binding Address}" FontSize="13" Foreground="#888888" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</mah:MetroWindow>