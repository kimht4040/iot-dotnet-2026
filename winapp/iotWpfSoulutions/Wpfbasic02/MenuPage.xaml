<Page x:Class="Wpfbasic02.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Wpfbasic02"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="950"
      Title="MenuPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Content="1123" Click="Button_Click_3"/>
            <Button Content="1123" Click="Button_Click_2"/>
            <Button Content="1123"/>
            <Button x:Name="btnMenu4" Content="윈폼바인딩"/>
            

        </StackPanel>
        <Grid Grid.Row="1">
            <Button Content="1123"/>
            <Button Content="1123"/>
            <Button Content="1123"/>
            <Button Content="1123" Margin="20, 40, 30, 50" Click="Button_Click_1"/>
        </Grid>

        <DockPanel Grid.Row="2">
            <Button Content="1123" DockPanel.Dock="Top" Click="Button_Click"/>
            <Button Content="1123" DockPanel.Dock="Left"/>
            <Button Content="1123" DockPanel.Dock="Right"/>
            <Button Content="1123" DockPanel.Dock="Bottom"/>
            <Button Content="1123" DockPanel.Dock="Bottom"/>
        </DockPanel>
        

    </Grid>
</Page>
