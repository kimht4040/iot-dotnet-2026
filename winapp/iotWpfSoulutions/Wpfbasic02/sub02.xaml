<Page x:Class="Wpfbasic02.sub02"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Wpfbasic02"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="sub02"
      Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="단순컨트롤" Background="Beige"/>

        <DataGrid x:Name="dataGrid" Grid.Row="1" Grid.Column="0" Grid.RowSpan="2"
                  Grid.ColumnSpan="1" AutoGenerateColumns="True" Margin="5"
                  SelectionMode="Single" SelectedItem="{Binding SelectedEmployee}"
                  IsReadOnly="True">
            
        </DataGrid>


        <GroupBox Grid.Column="1" Grid.Row="1" Margin="5" Header="상세정보">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Margin="10" TextOptions.TextHintingMode="Animated"
                         Text="{Binding SelectedEmployee.Id}">
                    
                </TextBox>
                <TextBox Grid.Row="1" Margin="10" TextOptions.TextHintingMode="Animated" >

                </TextBox>
                <TextBox Grid.Row="2" Margin="10" TextOptions.TextHintingMode="Animated" >

                </TextBox>
                <TextBox Grid.Row="3" Margin="10" TextOptions.TextHintingMode="Animated" >

                </TextBox>
                <TextBox Grid.Row="4" Margin="10" TextOptions.TextHintingMode="Animated" >

                </TextBox>
                
            </Grid>
        </GroupBox>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="new" Margin="5, 10" Width="70"></Button>
            <Button Content="save" Margin="5, 10" Width="70"></Button>
            <Button Content="delete" Margin="5, 10" Width="70"></Button>
        </StackPanel>

    </Grid>
</Page>