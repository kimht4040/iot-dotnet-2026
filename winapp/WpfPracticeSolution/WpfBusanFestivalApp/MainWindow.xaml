<mah:MetroWindow x:Class="WpfBusanFestivalApp.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
                 Title="부산 축제정보 V1.0"
                 Width="1200"
                 Height="800"
                 WindowStartupLocation="CenterScreen"
                 GlowBrush="#B92F58"
                 BorderBrush="#B92F58"
                 BorderThickness="1"
                 TitleCharacterCasing="Normal"
                 WindowTitleBrush="#B92F58"
                 NonActiveWindowTitleBrush="#B92F58"
                 >

    <mah:MetroWindow.Resources>

        <SolidColorBrush x:Key="MainPinkBrush" Color="#B92F58"/>
        <SolidColorBrush x:Key="SelectPinkBrush" Color="#C75A78"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="48"/>
        </Style>

    </mah:MetroWindow.Resources>

    <DockPanel Background="#F7F7F7">

        <!-- 하단 상태바 -->
        <StatusBar DockPanel.Dock="Bottom"
                   Height="28"
                   Background="{StaticResource MainPinkBrush}"
                   Foreground="White">
            <StatusBarItem>
                <TextBlock Text="데이터포털 API 활용앱"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtStatus" Text="0건 조회됨" Margin="0,0,10,0"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 제목 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock Text="부산 축제정보"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#111"
                           Margin="12,10,0,8"/>
                <mah:MetroProgressBar x:Name="PgbLoading"
                                      Width="200"
                                      Margin="20,0,0,0"
                                      VerticalAlignment="Center"
                                      IsIndeterminate="True"
                                      Visibility="Collapsed"/>
            </StackPanel>

            <!-- 검색 영역 -->
            <Grid Grid.Row="1" Margin="10,0,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock Text="페이지번호"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Margin="0,0,8,0"/>

                    <mah:NumericUpDown x:Name="NumPageNo"
                                   Width="70"
                                   Height="38"
                                   Minimum="1"
                                   Value="1"
                                   FontSize="16"
                                   Margin="0,0,12,0"/>

                    <TextBlock Text="결과수"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Margin="0,0,8,0"/>

                    <mah:NumericUpDown x:Name="NumRows"
                                   Width="70"
                                   Height="38"
                                   Minimum="1"
                                   Maximum="100"
                                   Value="10"
                                   FontSize="16"
                                   Margin="0,0,12,0"/>

                    <Button x:Name="BtnSearch"
                            Width="75"
                            Height="38"
                            Content="검색"
                            Background="{StaticResource MainPinkBrush}"
                            Foreground="White"
                            FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- 데이터 및 브라우저 영역 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- 데이터 목록 -->
                <DataGrid Grid.Column="0"
                          x:Name="DgFestival"
                          Margin="10,0,5,10"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          Background="White"
                          AlternatingRowBackground="#FAFAFA"
                          SelectionChanged="DgFestival_SelectionChanged"
                          >

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="순번"
                                            Binding="{Binding UcSeq}"
                                            Width="55"/>

                        <DataGridTemplateColumn Header="대표이미지" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding MainImgNormal}"
                                           Width="60"
                                           Height="42"
                                           Stretch="UniformToFill"
                                           Margin="4"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="축제명"
                                            Binding="{Binding Title}"
                                            Width="*"/>

                        <DataGridTextColumn Header="구군"
                                            Binding="{Binding GugunNm}"
                                            Width="80"/>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- 웹 브라우저 -->
                <cef:ChromiumWebBrowser Grid.Column="1"
                                        x:Name="BrsFestival"
                                        Margin="5,0,10,10"
                                        Address="https://www.google.com"/>
            </Grid>
        </Grid>
    </DockPanel>
</mah:MetroWindow>