<Window x:Class="WpfCafeKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfCafeKiosk"
        mc:Ignorable="d"
        Title="Cafe KIOSK" Height="800" Width="600"        
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#EEEEEE" Loaded="Window_Loaded">

    <materialDesign:DialogHost x:Name="RootDialog" CloseOnClickAway="True">
        <materialDesign:DialogHost.DialogContent>
            <materialDesign:Card Width="280" Padding="25" UniformCornerRadius="6">
                <StackPanel>
                    <TextBlock Text="주문내역이 없습니다" FontSize="16" FontWeight="Bold" TextAlignment="Center" Margin="0,10" />

                    <Button Content="확인" HorizontalAlignment="Center" Background="#FF5A45" Foreground="White" BorderThickness="0"           FontWeight="Bold" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" />
                </StackPanel>
            </materialDesign:Card>                                 
        </materialDesign:DialogHost.DialogContent>
        

        <!-- 키오스크 메인윈도우 기본화면 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- 상단 헤더 -->
            <Grid Background="#FF5A45">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnHome" Grid.Column="0" Width="50" Height="50" Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}" Click="BtnHome_Click">
                    <Button.Content>
                        <Grid>
                            <iconPacks:PackIconBootstrapIcons Kind="HouseFill" Height="30" Width="30" Foreground="White" />
                        </Grid>
                    </Button.Content>
                </Button>

                <Label Grid.Column="1" Content="CAFE KIOSK"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="30" FontWeight="ExtraBold"
                       Foreground="White"
                        />

                <Button Grid.Column="2" Width="50" Height="50" Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <Button.Content>
                        <Grid>
                            <iconPacks:PackIconBootstrapIcons Kind="PlusCircleFill" Height="30" Width="30" Foreground="White" />
                        </Grid>
                    </Button.Content>
                </Button>
            </Grid>

            <!-- 카테고리탭 -->
            <Grid Grid.Row="1">
                <TabControl 
                    materialDesign:ColorZoneAssist.Background="#FF5A45"
                    materialDesign:ColorZoneAssist.Foreground="White"
                    materialDesign:ColorZoneAssist.Mode="SecondaryMid"
                    Style="{StaticResource MaterialDesignFilledTabControl}">
                    <TabItem x:Name="TabAll" Header="전체 메뉴" Style="{StaticResource MaterialDesignTabItem}">
                        <UniformGrid x:Name="MenuPanel" Margin="10" Columns="3" Rows="2">
                            <!-- 버튼 디자인 완료본 -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}"                                
                                    materialDesign:ButtonAssist.CornerRadius="5"
                                    Margin="5" Padding="0" Background="White"
                                    Height="200"
                                    Tag="아메리카노|3000|/Images/americano.png" Click="Menu_Click">
                                <materialDesign:Card UniformCornerRadius="5" Padding="0">
                                    <Grid>
                                        <Image Source="/Images/americano.png" Stretch="Fill" />
                                        <Border Background="#CCFFFFFF" VerticalAlignment="Bottom" Height="42" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,5">
                                            <TextBlock Text="아메리카노" FontSize="14" FontWeight="Bold" Foreground="DimGray" TextAlignment="Center" />
                                            <TextBlock Text="3,000원" FontSize="12" FontWeight="Heavy" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Button>
                          <Button Style="{StaticResource MaterialDesignFlatButton}" materialDesign:ButtonAssist.CornerRadius="5" Margin="5" Padding="0" Background="White" Height="200" Tag="망고주스|5000|/Images/mangojuice.png" Click="Menu_Click">
                                <materialDesign:Card UniformCornerRadius="5" Padding="0">
                                    <Grid>
                                        <Image Source="/Images/mangojuice.png" Stretch="Fill" />
                                        <Border Background="#CCFFFFFF" VerticalAlignment="Bottom" Height="42" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,5">
                                            <TextBlock Text="망고주스" FontSize="14" TextAlignment="Center" />
                                            <TextBlock Text="5,000원" FontSize="12" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Button>
                          <Button Style="{StaticResource MaterialDesignFlatButton}" materialDesign:ButtonAssist.CornerRadius="5" Margin="5" Padding="0" Background="White" Height="200" Tag="카페라떼|4000|/Images/latte.png" Click="Menu_Click">
                                <materialDesign:Card UniformCornerRadius="5" Padding="0">
                                    <Grid>
                                        <Image Source="/Images/latte.png" Stretch="Fill" />
                                        <Border Background="#CCFFFFFF" VerticalAlignment="Bottom" Height="42" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,5">
                                            <TextBlock Text="카페라떼" FontSize="14" TextAlignment="Center" />
                                            <TextBlock Text="4,000원" FontSize="12" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Button>
                          <Button Style="{StaticResource MaterialDesignFlatButton}" materialDesign:ButtonAssist.CornerRadius="5" Margin="5" Padding="0" Background="White" Height="200" Tag="헤이즐럿라떼|4500|/Images/hazelnut.png" Click="Menu_Click">
                                <materialDesign:Card UniformCornerRadius="5" Padding="0">
                                    <Grid>
                                        <Image Source="/Images/hazelnut.png" Stretch="Fill" />
                                        <Border Background="#CCFFFFFF" VerticalAlignment="Bottom" Height="42" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,5">
                                            <TextBlock Text="헤이즐럿라떼" FontSize="14" TextAlignment="Center" />
                                            <TextBlock Text="4,500원" FontSize="12" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Button>
                          <Button Style="{StaticResource MaterialDesignFlatButton}" materialDesign:ButtonAssist.CornerRadius="5" Margin="5" Padding="0" Background="White" Height="200" Tag="아이스아메리카노|3500|/Images/iceamericano.png" Click="Menu_Click">
                                <materialDesign:Card UniformCornerRadius="5" Padding="0">
                                    <Grid>
                                        <Image Source="/Images/iceamericano.png" Stretch="Fill" />
                                        <Border Background="#CCFFFFFF" VerticalAlignment="Bottom" Height="42" />
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,5">
                                            <TextBlock Text="아이스아메리카노" FontSize="14" TextAlignment="Center" />
                                            <TextBlock Text="3,500원" FontSize="12" TextAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                            </Button>
                        </UniformGrid>
                    </TabItem>
                    <TabItem x:Name="TabHot" Header="HOT">
                        <TextBlock Margin="8" Text="Custom Tab 2" />
                    </TabItem>
                    <TabItem x:Name="TabCold" Header="ICE">
                        <TextBlock Margin="8" Text="Custom Tab 2" />
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- 하단 주문리스트 및 결제영역 -->
            <Grid Grid.Row="2" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 주문리스트 영역 -->
                <Border Grid.Column="0" Background="White" CornerRadius="6" Margin="0,0,5,0" Padding="8">
                    <ListBox x:Name="LstOrder" BorderThickness="0" Background="Transparent" FontSize="14"
                             HorizontalContentAlignment="Stretch">
                        <!-- ListBoxItem을 ItemTemplate으로 변환(재사용) -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Width="20" Height="20" Padding="0"
                                            Background="Transparent" BorderThickness="0" Click="BtnRemoveOrder_Click"
                                            Tag="{Binding}">
                                        <iconPacks:PackIconMaterialDesign Kind="RemoveCircleSharp" />
                                    </Button>

                                    <TextBlock Grid.Column="1" Text="{Binding MenuName}" VerticalAlignment="Center" FontWeight="Bold" Foreground="DimGray" />

                                    <TextBlock Grid.Column="2" Text="{Binding Count, StringFormat={}{0:N0}잔}" VerticalAlignment="Center" FontWeight="Bold" Foreground="DimGray" />

                                    <TextBlock Grid.Column="3" Text="{Binding TotalPrice, StringFormat={}{0:N0}원}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#FF5A45" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- 오른쪽 버튼 영역 -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="남은시간" FontSize="18" FontWeight="Bold" TextAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtRemainTime" Text="00" FontSize="24" FontWeight="Bold" Foreground="#FF5A45" />
                            <TextBlock Text="초" FontSize="18" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,1" />
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="BtnClearAll" Grid.Column="1" Content="전체 삭제" Padding="0" Style="{StaticResource MaterialDesignFlatDarkBgButton}" Background="#5D5353" FontWeight="Bold" BorderThickness="0" Height="50" Click="BtnClearAll_Click"  />

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Background="White" CornerRadius="6" Margin="0,2,0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="선택한 상품" Margin="20,10" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"></TextBlock>
                            <TextBlock x:Name="TxtOrderCount" Text="0개" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#FF5A45" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnPay" Grid.Row="2" Grid.ColumnSpan="2" Background="#FF5A45" Foreground="White" Height="50" Click="BtnPay_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTotalPrice" Text="0원" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="결제" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
    
</Window>
