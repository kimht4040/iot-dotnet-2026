<mah:MetroWindow
    x:Class="WpfBusanFestivalApp.FestivalDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:cefSharp="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
    xmlns:local="clr-namespace:WpfBusanFestivalApp"
    mc:Ignorable="d"
    Title="축제 상세정보" Height="800" Width="800"
    WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <Border CornerRadius="12"
                    Background="#EEE"
                    Height="320"
                    ClipToBounds="True">
                <Image Source="{Binding MainImgNormal}"
                       Stretch="UniformToFill"/>
            </Border>

            <TextBlock Text="{Binding Title}"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,20,0,10"
                       TextWrapping="Wrap"/>

            <Separator Margin="0,5,0,15"/>

            <TextBlock Text="구군"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding GugunNm}"
                       Margin="0,0,0,12"/>

            <TextBlock Text="주소"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding Addr1}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock Text="장소"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding Place}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <cefSharp:ChromiumWebBrowser x:Name="MapBrowser" Height="200" Background="Azure" Margin="5" />

            <TextBlock Text="기간 / 시간"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding UsageDayWeekAndTime}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock Text="요금"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding UsageAmount}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock Text="연락처"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding CntctTel}"
                       Margin="0,0,0,12"/>

            <TextBlock Text="홈페이지"
                       FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap"
                       Foreground="DodgerBlue"
                       Margin="0,0,0,12">
                <Hyperlink Click="Homepage_Click">
                    <Run Text="{Binding HomepageUrl}" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="교통정보"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding TrfcInfo}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <TextBlock Text="상세내용"
                       FontWeight="Bold"
                       FontSize="18"
                       Margin="0,15,0,8"/>

            <!--<TextBlock Text="{Binding ItemCntnts}"
                       TextWrapping="Wrap"
                       LineHeight="24"
                       Margin="0,0,0,20"/>-->
            <RichTextBox x:Name="RtbItemContents"
                         IsReadOnly="True"
                         BorderThickness="0"                         
                         Margin="0,0,0,20"/>
        </StackPanel>
    </ScrollViewer>
</mah:MetroWindow>
