<Page x:Class="WpfBasic02Navi.Sub02Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="일반 작업화면" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label Content="일반 작업화면" Grid.Row="0" Grid.Column="0" />
        <DataGrid x:Name="DgrEmployees" Grid.Row="1" Grid.RowSpan="2" AutoGenerateColumns="True" Margin="5"
                  IsReadOnly="True" SelectionMode="Single" 
                  ItemsSource="{Binding Employees}"
                  SelectedItem="{Binding SelectedEmployee}">
        </DataGrid>

        <GroupBox Grid.Column="1" Grid.Row="1" Margin="5" 
                  Header="상세정보" 
                  DataContext="{Binding SelectedItem, ElementName=DgrEmployees}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Margin="10" Text="{Binding Id}" />
                <TextBox Grid.Row="1" Margin="10" Text="{Binding Name}" />
                <!-- TextBox Grid.Row="2" Margin="10" Text="{Binding Department}" /-->
                <ComboBox Grid.Row="2" Margin="10" 
                          ItemsSource="{Binding DataContext.Departments, RelativeSource={RelativeSource AncestorType=Page}}"
                          SelectedItem="{Binding Department, Mode=TwoWay}"/>
                <TextBox Grid.Row="3" Margin="10" Text="{Binding Salary}" />
                <DatePicker Grid.Row="4" Margin="10, 14" Text="{Binding HireDate, Mode=TwoWay}" />
                <CheckBox Grid.Row="5" Margin="10" IsChecked="{Binding IsActive}" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="신규" Margin="5,10" Width="70" />
            <Button Content="저장" Margin="5,10" Width="70" />
            <Button Content="삭제" Margin="5,10" Width="70" />

        </StackPanel>
    </Grid>

</Page>
