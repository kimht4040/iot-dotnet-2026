<mah:MetroWindow
    x:Class="WpfBasic04DbApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:WpfBasic04DbApp"
    mc:Ignorable="d"
    Title="Books Database" Height="500" Width="1050" Loaded="MetroWindow_Loaded">
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <iconPacks:PackIconLucide Kind="LibraryBig" Margin="10,7,0,0" Foreground="White" />
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- 상태표시줄을 위해서 RowDefinition 추가 -->
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>
        
        <!--DataGrid d:ItemsSource="{d:SampleData ItemCount=5}"/ -->
        <DataGrid x:Name="GrdBooks" Margin="5"
                  AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="GrdBooks_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="순번" Binding="{Binding book_idx}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="저자" Binding="{Binding author}" />
                <DataGridTextColumn Header="장르코드" Binding="{Binding div_code}" Visibility="Hidden" />
                <DataGridTextColumn Header="책장르" Binding="{Binding div_name}" />
                <DataGridTextColumn Header="책이름" Binding="{Binding book_name}" />
                <DataGridTextColumn Header="출판일" Binding="{Binding release_dt, StringFormat='yyyy-MM-dd'}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="Margin" Value="5,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ISBN" Binding="{Binding isbn}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="Margin" Value="5,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="책가격" Binding="{Binding price, StringFormat={}{0:N0}원}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Column="1" Margin="5" Header="책 상세">
            <StackPanel>
                

                <!-- mah:TextBoxHelper.UseFloatingWatermark="True" -->
                <mah:NumericUpDown 
                    x:Name="NudBookIdx" Grid.Row="0" Minimum="0" IsReadOnly="True" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="순번"
                    mah:TextBoxHelper.WatermarkAlignment="Left"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    />
                <TextBox 
                    x:Name="TxtAuthor" Grid.Row="1" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="저자"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    />
                <ComboBox 
                    x:Name="CboDivCode" Grid.Row="2" Margin="5"
                    SelectedValuePath="div_code"                    
                    DisplayMemberPath="div_name"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="책장르"
                    mah:TextBoxHelper.ClearTextButton="True" 
                    mah:TextBoxHelper.UseFloatingWatermark="True"/>
                <TextBox 
                    x:Name="TxtBookName" Grid.Row="3" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="책제목"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"/>
                <DatePicker 
                    x:Name="DtpReleaseDt" Grid.Row="4" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="출판일"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"/>
                <TextBox 
                    x:Name="TxtIsbn" Grid.Row="5" Margin="5" 
                    MaxLength="13"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="ISBN"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"/>
                <TextBox 
                    x:Name="TxtPrice" Grid.Row="6" Margin="5"
                    mah:TextBoxHelper.AutoWatermark="True"
                    mah:TextBoxHelper.Watermark="책가격"
                    mah:TextBoxHelper.ClearTextButton="True"
                    mah:TextBoxHelper.UseFloatingWatermark="True"/>

                <StackPanel Grid.Row="7" Orientation="Horizontal">
                    <Button x:Name="BtnNew" Width="100" Content="신규" Margin="5" 
                            Style="{StaticResource MahApps.Styles.Button.Dialogs.Accent}" Click="BtnNew_Click"/>
                    <Button x:Name="BtnSave" Width="100" Content="저장" Margin="5"
                            Style="{StaticResource MahApps.Styles.Button.Dialogs.AccentHighlight}" Click="BtnSave_Click"/>
                    <Button x:Name="BtnDelete" Width="100" Content="삭제" Margin="5"
                            Padding="5,7"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare}" Click="BtnDelete_Click"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <StatusBar Grid.Row="1" Grid.ColumnSpan="2">
            <StatusBarItem Content="BookRentalShop Books v0.2" Margin="5,0" />
            <Separator Background="White" />
            <StatusBarItem x:Name="SbiResMsg" />
        </StatusBar>

    </Grid>
</mah:MetroWindow>
